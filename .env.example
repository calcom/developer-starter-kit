# Cal.com API v2 — get your key at https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=
CAL_API_URL=https://api.cal.com/v2
CAL_API_VERSION=2024-08-13

# Default booker shortcut used by the landing page: /book/{username}/{event-slug}
NEXT_PUBLIC_CAL_USERNAME=
NEXT_PUBLIC_CAL_EVENT_TYPE_SLUG=30min

# Optional: your brand
NEXT_PUBLIC_BRAND_NAME=Acme
